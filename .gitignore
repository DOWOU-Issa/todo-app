# ----------------------------
# Fichiers audio (optionnel)
# Les fichiers audio sont exclus car volumineux
# Les utilisateurs devront télécharger leur propre musique
# ----------------------------
assets/sounds/*.mp3
assets/sounds/*.wav
assets/sounds/*.ogg
!assets/sounds/.gitkeep

# Si tu veux garder la musique, commente les lignes ci-dessus
# et décommente celle-ci :
# assets/sounds/jazz-cafe.mp3

